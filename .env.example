# App (SEO + OG previews)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Production: set to your real URL (e.g. https://sthirr.vercel.app or https://sthir.in)
# Do NOT leave an old/deleted *.vercel.app URL here — breaks WhatsApp link previews.

# Founding cohort — free programs before public pricing (set false when launching paid)
NEXT_PUBLIC_FOUNDING_FREE=true
NEXT_PUBLIC_FOUNDING_FREE_UNTIL=July 2026

# Supabase — for SBD video uploads (intake form)
# Create project at supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
